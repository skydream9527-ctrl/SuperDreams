<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".SuperDreamsApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SuperDreams">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SuperDreams">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.KeywordActivity"
            android:exported="false"
            android:theme="@style/Theme.SuperDreams" />

        <activity
            android:name=".ui.TodoActivity"
            android:exported="false"
            android:theme="@style/Theme.SuperDreams" />

        <activity
            android:name=".ui.DetailActivity"
            android:exported="false"
            android:theme="@style/Theme.SuperDreams" />

        <activity
            android:name=".ui.HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.SuperDreams" />

        <activity
            android:name=".ui.MyActivity"
            android:exported="false"
            android:theme="@style/Theme.SuperDreams" />

        <activity
            android:name=".ui.WidgetActivity"
            android:exported="false"
            android:theme="@style/Theme.SuperDreams.Transparent"
            android:excludeFromRecents="true"
            android:taskAffinity="" />

        <receiver
            android:name=".widget.SuperDreamsWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/superdreams_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.DismissActionReceiver"
            android:exported="false" />

        <service
            android:name=".widget.WidgetRemoteViewsService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <service
            android:name=".notification.NotificationCaptureService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>
</manifest>
