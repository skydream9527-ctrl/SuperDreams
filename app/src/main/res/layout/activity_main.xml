<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F7FB"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/home_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        android:background="@drawable/home_header_bg">

        <TextView
            android:id="@+id/home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Super Dreams"
            android:textColor="#2B2B3A"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/home_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="您的信息流和待办事项"
            android:textColor="#6F7285"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_add_widget"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="添加小部件"
                    android:textColor="#2F3347"
                    android:textSize="13sp"
                    android:background="@drawable/home_btn_primary_bg"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_manage_keywords"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="🔑 关键词"
                    android:textColor="#2F3347"
                    android:textSize="13sp"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_manage_todos"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="📋 待办"
                    android:textColor="#2F3347"
                    android:textSize="13sp"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_history"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="📚 历史"
                    android:textColor="#2F3347"
                    android:textSize="13sp"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_my"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="🙋 我的"
                    android:textColor="#2F3347"
                    android:textSize="13sp"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/home_swipe_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:text="← 左滑卡片可移除"
        android:textColor="#8B90A7"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/main_feed_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/home_app_search_entry"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/home_search_bg"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:text="🔍 搜索并打开应用"
        android:textColor="#6F7285"
        android:textSize="14sp" />
</LinearLayout>
