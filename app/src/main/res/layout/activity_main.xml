<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/home_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/home_header_bg"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        android:paddingTop="36dp">

        <TextView
            android:id="@+id/home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Super Dreams"
            android:textColor="#2B2B3A"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/home_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="您的信息流和待办事项"
            android:textColor="#6F7285"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_add_widget"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_btn_primary_bg"
                    android:text="添加小部件"
                    android:textAllCaps="false"
                    android:textColor="#2F3347"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_manage_keywords"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:text="🔑 关键词"
                    android:textAllCaps="false"
                    android:textColor="#2F3347"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_manage_todos"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:text="📋 待办"
                    android:textAllCaps="false"
                    android:textColor="#2F3347"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_history"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:text="📚 历史"
                    android:textAllCaps="false"
                    android:textColor="#2F3347"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_my"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_btn_secondary_bg"
                    android:text="🙋 我的"
                    android:textAllCaps="false"
                    android:textColor="#2F3347"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/main_content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/page_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/home_swipe_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:text="← 左滑卡片可移除"
                android:textColor="#8B90A7"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/main_feed_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="12dp"
                android:scrollbars="none" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/page_browser"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/browser_engine_spinner"
                    android:layout_width="106dp"
                    android:layout_height="44dp"
                    android:background="@drawable/home_btn_secondary_bg" />

                <EditText
                    android:id="@+id/browser_query_input"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_search_bg"
                    android:hint="输入网址或关键词"
                    android:imeOptions="actionSearch"
                    android:inputType="textUri"
                    android:paddingHorizontal="12dp"
                    android:textColor="#2F3347"
                    android:textColorHint="#8791A9"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/browser_go_btn"
                    android:layout_width="70dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/home_btn_primary_bg"
                    android:text="前往"
                    android:textAllCaps="false"
                    android:textColor="#2F3347"
                    android:textSize="13sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/browser_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="0"
                android:visibility="gone" />

            <WebView
                android:id="@+id/browser_webview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/home_bottom_tab"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/tab_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/home_btn_primary_bg"
            android:text="列表"
            android:textAllCaps="false"
            android:textColor="#2F3347"
            android:textSize="13sp" />

        <Button
            android:id="@+id/tab_browser"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/home_btn_secondary_bg"
            android:text="浏览器"
            android:textAllCaps="false"
            android:textColor="#2F3347"
            android:textSize="13sp" />

        <Button
            android:id="@+id/tab_apps"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/home_btn_secondary_bg"
            android:text="桌面APP"
            android:textAllCaps="false"
            android:textColor="#2F3347"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
