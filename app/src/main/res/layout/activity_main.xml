<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:background="@drawable/header_background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Super Dreams"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="您的信息流和待办事项"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_add_widget"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="添加桌面小部件"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_add_widget_bg"
                android:paddingHorizontal="20dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_manage_keywords"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:text="🔑 关键词"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_crawl_bg"
                android:paddingHorizontal="16dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_manage_todos"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="📋 待办"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_add_widget_bg"
                android:paddingHorizontal="16dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_history"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="📚 历史"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_add_widget_bg"
                android:paddingHorizontal="16dp"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:text="← 左滑卡片可移除"
        android:textColor="#60FFFFFF"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/main_feed_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="none" />
</LinearLayout>
