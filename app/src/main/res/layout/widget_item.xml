<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_card_root"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@drawable/item_background"
    android:paddingStart="4dp"
    android:paddingEnd="12dp"
    android:gravity="center_vertical">

    <View
        android:id="@+id/item_type_indicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:background="@drawable/type_indicator_news" />

    <ImageView
        android:id="@+id/item_type_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_toEndOf="@id/item_type_indicator"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:src="@drawable/ic_news"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/item_type_icon"
        android:layout_toStartOf="@id/item_dismiss_btn"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/card_text_primary"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/item_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/card_text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/item_dismiss_btn"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_dismiss"
        android:padding="4dp"
        android:contentDescription="@null" />
</RelativeLayout>
