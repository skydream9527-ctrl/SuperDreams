<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/app_list_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/app_list_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:contentDescription="返回"
            android:padding="6dp"
            android:src="@drawable/ic_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/app_list_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="桌面APP"
                android:textColor="#2B2B3A"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/app_list_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击即可打开"
                android:textColor="#6F7285"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/app_list_search_input"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/home_search_bg"
        android:hint="搜索应用名或包名"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textColor="#2F3347"
        android:textColorHint="#8791A9"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/app_list_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:textColor="#8B90A7"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/app_list_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="8dp"
        android:paddingBottom="12dp"
        android:scrollbars="none" />

</LinearLayout>
