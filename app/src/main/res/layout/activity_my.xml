<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/my_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F7FB"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/my_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_back"
            android:padding="6dp"
            android:contentDescription="返回" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/my_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的"
                android:textColor="#2B2B3A"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/my_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="近30天存储内容"
                android:textColor="#6F7285"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="设置"
            android:textColor="#2F3347"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/home_btn_secondary_bg"
            android:paddingHorizontal="14dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/my_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:textColor="#8B90A7"
        android:textSize="12sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <Button
                android:id="@+id/tab_notification"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="通知"
                android:textColor="#2F3347"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/home_btn_primary_bg"
                android:paddingHorizontal="16dp" />

            <Button
                android:id="@+id/tab_news"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="新闻"
                android:textColor="#2F3347"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/home_btn_secondary_bg"
                android:paddingHorizontal="16dp" />

            <Button
                android:id="@+id/tab_push"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="PUSH"
                android:textColor="#2F3347"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/home_btn_secondary_bg"
                android:paddingHorizontal="16dp" />

            <Button
                android:id="@+id/tab_todo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="待办"
                android:textColor="#2F3347"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/home_btn_secondary_bg"
                android:paddingHorizontal="16dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/my_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/my_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="近30天暂无数据"
        android:textColor="#8B90A7"
        android:textSize="15sp"
        android:visibility="gone" />

</LinearLayout>
