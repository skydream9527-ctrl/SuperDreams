<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:padding="6dp"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="历史记录"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/history_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Filter tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp">

        <LinearLayout
            android:id="@+id/filter_tabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <Button
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="全部"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_crawl_bg"
                android:paddingHorizontal="18dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/tab_news"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="新闻"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_add_widget_bg"
                android:paddingHorizontal="18dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/tab_notification"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="推送"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_add_widget_bg"
                android:paddingHorizontal="18dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/tab_todo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="待办"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_add_widget_bg"
                android:paddingHorizontal="18dp"
                android:textAllCaps="false" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/history_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="none" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/history_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="暂无历史记录"
        android:textColor="#60FFFFFF"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>
